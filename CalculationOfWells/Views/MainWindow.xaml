<Window x:Class="CalculationOfWells.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CalculationOfWells.Views"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10 10 10 10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" >
            <Button x:Name="btMybutton" Command="{Binding MyCommand}" />
        </Grid>

        <Grid Grid.Column="1" >
            <TextBox x:Name="tbMytextbox" Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

    </Grid>
</Window>
